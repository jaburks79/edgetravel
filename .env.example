# EdgeTravel Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

DJANGO_SECRET_KEY=change-me-to-a-long-random-string-use-python-secrets-module
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite for local dev)
# DATABASE_URL=postgres://user:password@host:5432/edgetravel

# Email (optional, console backend used in debug mode)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@edgetravel.com
